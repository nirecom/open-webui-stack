# =============================================================================
# Open WebUI Stack - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Backend
# ---------------------------------------------------------------------------
# If using litellm-stack on the same Docker host, use the container name:
#   OPENAI_API_BASE_URLS=http://litellm-proxy:4000/v1
#   OPENAI_API_KEYS=<your-litellm-master-key>
#
# If connecting directly to llama-server on another host:
#   OPENAI_API_BASE_URLS=https://<your-llm-server>/v1
#   OPENAI_API_KEYS=dummy
#
OPENAI_API_BASE_URLS=http://litellm-proxy:4000/v1
OPENAI_API_KEYS=your-api-key-here

# ---------------------------------------------------------------------------
# Data / Certificate Paths (absolute paths on host)
# ---------------------------------------------------------------------------
# Open WebUI data directory (webui.db, uploads/, etc.)
OPEN_WEBUI_DATA_DIR=/path/to/open-webui-data

# CA certificate generated by mkcert etc. (required if LLM server uses self-signed cert)
CA_CERT_PATH=/path/to/rootCA.pem

# ---------------------------------------------------------------------------
# Ports (optional, defaults shown)
# ---------------------------------------------------------------------------
# OPEN_WEBUI_PORT=3000
# SEARXNG_PORT=8888

# ---------------------------------------------------------------------------
# SearXNG
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SEARXNG_SECRET=your-searxng-secret-here

# ---------------------------------------------------------------------------
# Cloudflare Tunnel
# ---------------------------------------------------------------------------
# Obtain from: Cloudflare Zero Trust Dashboard > Networks > Tunnels > Configure
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
